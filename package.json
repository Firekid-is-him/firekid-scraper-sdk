{
  "name": "@firekid/scraper",
  "version": "1.0.0",
  "description": "The most advanced web scraping machine ever built",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "firekid-scraper": "./dist/bin/firekid-scraper.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prestart": "node scripts/prestart.js",
    "start": "node dist/bin/firekid-scraper.js",
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "scraping",
    "playwright",
    "automation",
    "web-scraper",
    "cloudflare-bypass",
    "anti-detection",
    "fingerprinting"
  ],
  "author": "Firekid",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.0.0",
    "chokidar": "^4.0.1",
    "commander": "^12.1.0",
    "croner": "^9.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "playwright": "^1.47.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "winston": "^3.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "nodemon": "^3.1.4",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
