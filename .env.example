# ============================================
# FIREKID SCRAPER CONFIGURATION
# ============================================

# Browser Settings
HEADLESS=true
MAX_QUEUE_WORKERS=5
BROWSER_TIMEOUT=30000

# Cloudflare Bypass
CF_BYPASS=auto
# Options: auto, manual, skip
TURNSTILE_SOLVER=manual
# Options: skip, manual, 2captcha, capsolver

# Captcha Solver (Optional - for auto-solve)
CAPTCHA_API_KEY=

# Web Server
API_ENABLED=false
API_PORT=3000
API_KEY=

# Proxy
PROXY_ENABLED=false
PROXY_URL=

# Storage
DATA_DIR=./data
PATTERNS_DB=./data/patterns.db
SESSIONS_DB=./data/sessions.db

# Logging
LOG_LEVEL=info
# Options: error, warn, info, debug

# Recording
AUTO_HIDE_AFTER_SOLVE=true
RECORD_SCREENSHOTS=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=3600000

# Advanced
ENABLE_TELEMETRY=false
ENABLE_ANALYTICS=false
